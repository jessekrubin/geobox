{
  "name": "@jsse/geobox",
  "type": "module",
  "version": "0.6.0",
  "description": "geo + typebox => geo-schemas",
  "readme": "README.md",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/lib/esm/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./lite": {
      "import": {
        "types": "./dist/lib/esm/index.d.ts",
        "default": "./dist/lite.js"
      },
      "require": {
        "types": "./dist/lib/cjs/index.d.ts",
        "default": "./dist/lite.cjs"
      }
    },
    "./lib/*.js": {
      "import": {
        "types": "./dist/lib/esm/*.d.ts",
        "default": "./dist/lib/esm/*"
      }
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/lib/cjs/index.d.ts",
  "files": [
    "!**/*.spec.*",
    "!**/*.test-d.*",
    "!**/*.test.*",
    "!**/*.tsbuildinfo",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "pnpm run test && pnpm run build:tsdown && pnpm run build:tsc && pnpm run build:post && pnpm run typecheck && pnpm run lint",
    "build:cjs": "tsc -p tsconfig.cjs.json --outDir dist/lib/cjs --module commonjs",
    "build:dts": "tsc --emitDeclarationOnly -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json --outDir dist/lib/esm --module nodenext --moduleResolution nodenext --declaration",
    "build:fast": "tsdown src/index.ts --format cjs,esm",
    "build:tsc": "tsc -b tsconfig.build.json",
    "build:post": "tsx scripts/post-build.mts",
    "build:tsdown": "tsdown src/index.ts --format cjs,esm --dts",
    "change": "changeset",
    "ci": "pnpm run test && pnpm run build:tsdown && pnpm run build:tsc && pnpm run lint",
    "ci:publish": "pnpm publish",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile && pnpm fmt",
    "cov": "vitest --coverage",
    "dev": "vitest watch --coverage",
    "fmt": "prettier --write .",
    "lint": "eslint .",
    "prepublish": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.dts.json --noEmit"
  },
  "peerDependencies": {
    "typebox": "^1.0.13"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@jsse/eslint-config": "^0.7.0",
    "@jsse/tsconfig": "^0.5.0",
    "@turf/helpers": "^7.3.4",
    "@turf/turf": "^7.3.4",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-antfu": "^3.2.2",
    "fastify": "^5.8.2",
    "glob": "^13.0.6",
    "prettier": "3.8.3",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typebox": "^1.1.6",
    "typescript": "~6.0.3",
    "vitest": "4.1.0"
  }
}
